# Dockerfile for RED Signaling Server
# Simple Node.js WebSocket server

FROM node:20-alpine

WORKDIR /app

COPY signaling/package*.json ./
RUN npm ci --only=production

COPY signaling/server.js ./

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=5s \
    CMD wget -qO- http://localhost:3001/health || exit 1

CMD ["node", "server.js"]
